generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                @id
  email                String                @unique
  name                 String?
  role                 String                @default("user")
  createdAt            DateTime              @default(now())
  avatarUrl            String?
  avatarKey            String?
  firstName            String?
  lastName             String?
  username             String?               @unique
  displayName          String?
  bio                  String?
  recipes              Recipe[]
  userPortionOverrides UserPortionOverride[]
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Recipe {
  id            String                   @id @default(cuid())
  authorId      String
  title         String
  bodyMd        String
  servings      Int                      @default(1)
  prepTime      String?
  parentId      String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  ingredients   Ingredient[]
  nutrition     Nutrition?
  photos        Photo[]
  author        User                     @relation(fields: [authorId], references: [id])
  parent        Recipe?                  @relation("Forks", fields: [parentId], references: [id])
  forks         Recipe[]                 @relation("Forks")

  @@index([createdAt])
}

model Ingredient {
  id       String              @id @default(cuid())
  recipeId String
  name     String
  qty      Float
  unit     String
  recipe   Recipe              @relation(fields: [recipeId], references: [id])
  foodMaps IngredientFoodMap[]
}

model Nutrition {
  recipeId    String   @id
  calories    Int
  proteinG    Float
  carbsG      Float
  fatG        Float
  fiberG      Float?   @default(0)
  sugarG      Float?   @default(0)
  healthScore Float?   @default(0)
  goal        String?  @default("general")
  computedAt  DateTime @default(now())
  recipe      Recipe   @relation(fields: [recipeId], references: [id])
}

model Photo {
  id          String  @id @default(cuid())
  recipeId    String
  s3Key       String
  width       Int
  height      Int
  isMainPhoto Boolean @default(false)
  recipe      Recipe  @relation(fields: [recipeId], references: [id])

  @@index([recipeId, isMainPhoto])
}


model Food {
  id                   String                @id @default(cuid())
  name                 String
  brand                String?               @db.VarChar(120)
  categoryId           String?
  source               String                @default("usda")
  verification         String                @default("unverified")
  densityGml           Float?
  kcal100              Float
  protein100           Float
  carbs100             Float
  fat100               Float
  fiber100             Float?
  sugar100             Float?
  popularity           Int                   @default(0)
  createdById          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  barcodes             Barcode[]
  aliases              FoodAlias[]
  units                FoodUnit[]
  ingredientMaps       IngredientFoodMap[]
  portionOverrides     PortionOverride[]
  userPortionOverrides UserPortionOverride[]
  logEntries           LogEntry[]

  @@unique([name, brand])
  @@index([name])
  @@index([brand])
  @@index([source])
  @@index([verification])
  @@index([categoryId])
  @@index([createdAt])
  @@index([popularity])
  @@index([verification, source])
  @@index([categoryId, verification])
}

model FdcFoodCache {
  id            Int                  @id
  description   String
  brandName     String?
  dataType      String
  nutrients     Json                 // nutrientsPer100g
  servingSize   Float?
  servingSizeUnit String?
  syncedAt      DateTime             @default(now())
  expiresAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  servings      FdcServingCache[]
  
  @@index([syncedAt])
  @@index([expiresAt])
}

model FdcServingCache {
  id                Int            @id @default(autoincrement())
  fdcId             Int
  description       String
  grams             Float
  volumeMl          Float?         // Volume in ml (for density-based conversions)
  derivedViaDensity Boolean        @default(false)
  densityGml        Float?         // Density in g/ml (stored inline for FDC)
  prepModifier      String?        // e.g., "cubed", "minced", "sliced"
  source            String         @default("fdc")
  isAiEstimated     Boolean        @default(false)
  confidence        Float?         // AI confidence score
  note              String?        // AI rationale or notes
  food              FdcFoodCache   @relation(fields: [fdcId], references: [id], onDelete: Cascade)
  
  @@unique([fdcId, description], name: "FdcServingCache_fdcId_description_key")
  @@index([fdcId])
  @@index([prepModifier])
}

model FatSecretFoodCache {
  id               String                     @id
  name             String
  brandName        String?
  foodType         String?
  country          String?
  description      String?
  defaultServingId String?
  source           String?                    @default("food.get.v4")
  confidence       Float?                     @default(0.9)
  nutrientsPer100g Json?
  legacyFoodId     String?                    @unique
  hash             String?
  syncedAt         DateTime                   @default(now())
  expiresAt        DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  densityEstimates FatSecretDensityEstimate[]
  aliases          FatSecretFoodAlias[]
  servings         FatSecretServingCache[]

  @@index([syncedAt])
  @@index([expiresAt])
  @@index([hash])
}

model FatSecretServingCache {
  id                     String                    @id
  foodId                 String
  measurementDescription String?
  numberOfUnits          Float?
  metricServingAmount    Float?
  metricServingUnit      String?
  servingWeightGrams     Float?
  volumeMl               Float?
  isVolume               Boolean                   @default(false)
  isDefault              Boolean                   @default(false)
  derivedViaDensity      Boolean                   @default(false)
  densityEstimateId      String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  source                 String?                   @default("fatsecret")
  confidence             Float?
  note                   String?
  densityEstimate        FatSecretDensityEstimate? @relation(fields: [densityEstimateId], references: [id])
  food                   FatSecretFoodCache        @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@index([foodId])
  @@index([isDefault])
  @@index([densityEstimateId])
}

model FatSecretFoodAlias {
  id        String             @id @default(cuid())
  foodId    String
  alias     String
  locale    String?            @db.VarChar(16)
  source    String?            @default("fatsecret")
  createdAt DateTime           @default(now())
  food      FatSecretFoodCache @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([foodId, alias])
  @@index([alias])
}

model FatSecretDensityEstimate {
  id         String                  @id @default(cuid())
  foodId     String
  densityGml Float
  source     String
  confidence Float?                  @default(0)
  notes      String?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  food       FatSecretFoodCache      @relation(fields: [foodId], references: [id], onDelete: Cascade)
  servings   FatSecretServingCache[]

  @@index([foodId])
  @@index([source])
}

model FatSecretCacheSyncRun {
  id             String    @id @default(cuid())
  status         String    @default("pending")
  totalRequested Int       @default(0)
  totalHydrated  Int       @default(0)
  totalFailed    Int       @default(0)
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  error          String?
  metadata       Json?

  @@index([status, startedAt])
}

model FoodUnit {
  id     String @id @default(cuid())
  foodId String
  label  String
  grams  Float
  Food   Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)
}

model Barcode {
  id     String @id @default(cuid())
  gtin   String @unique
  foodId String
  Food   Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)
}

model IngredientFoodMap {
  id           String     @id @default(cuid())
  ingredientId String
  foodId       String?
  fatsecretFoodId       String?
  fatsecretServingId    String?
  fatsecretGrams        Float?
  fatsecretConfidence   Float?
  fatsecretSource       String?
  aiGeneratedFoodId     String?
  pendingVolume         Boolean   @default(false)
  mappedBy     String
  confidence   Float      @default(0.0)
  useOnce      Boolean    @default(false)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  food         Food?      @relation(fields: [foodId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  aiGeneratedFood AiGeneratedFood? @relation(fields: [aiGeneratedFoodId], references: [id], onDelete: SetNull)

  @@index([ingredientId])
  @@index([foodId])
  @@index([fatsecretFoodId])
  @@index([aiGeneratedFoodId])
}

model FoodAlias {
  id     String @id @default(cuid())
  foodId String
  alias  String
  food   Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([foodId, alias])
  @@index([foodId])
  @@index([alias])
}

model PortionOverride {
  id        String   @id @default(cuid())
  foodId    String
  unit      String
  grams     Float
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([foodId, unit])
  @@index([unit])
}

model UserPortionOverride {
  id        String   @id @default(cuid())
  userId    String
  foodId    String
  unit      String
  grams     Float
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, foodId, unit])
  @@index([userId, foodId])
}



model GlobalIngredientMapping {
  id                  String   @id @default(cuid())
  normalizedName      String   @unique
  fatsecretFoodId     String?
  fatsecretServingId  String?
  fdcId               Int?
  source              String   // "fatsecret" | "fdc"
  confidence          Float
  usageCount          Int      @default(1)
  lastUsed            DateTime @default(now())
  createdBy           String?
  isUserOverride      Boolean  @default(false)
  createdAt           DateTime @default(now())
  
  @@index([normalizedName])
  @@index([confidence])
}

model IngredientCleanupPattern {
  id            String   @id @default(cuid())
  
  // Pattern definition
  pattern       String   @unique
  patternType   PatternType
  replacement   String
  description   String?
  
  // Learning metadata
  source        PatternSource
  confidence    Float    @default(0.8)
  
  // Usage tracking
  usageCount    Int      @default(0)
  successCount  Int      @default(0)
  failureCount  Int      @default(0)
  
  // Computed metrics
  successRate   Float?
  
  // Timestamps
  createdAt     DateTime @default(now())
  lastUsed      DateTime @default(now())
  
  // Relations
  appliedTo     IngredientCleanupApplication[]
  
  @@index([patternType])
  @@index([source])
  @@index([confidence])
  @@index([successRate])
}

model IngredientCleanupApplication {
  id               String   @id @default(cuid())
  
  // What was cleaned
  rawInput         String
  cleanedOutput    String
  
  // Which pattern was used
  patternId        String
  pattern          IngredientCleanupPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
  
  // Context
  recipeId         String?
  ingredientId     String?
  
  // Outcome
  mappingSucceeded Boolean?
  confidenceScore  Float?
  
  // Timestamp
  appliedAt        DateTime @default(now())
  
  @@index([patternId])
  @@index([mappingSucceeded])
  @@index([appliedAt])
}

enum PatternType {
  MEASUREMENT_PREFIX
  MEASUREMENT_SUFFIX
  PREP_PHRASE
  SIZE_PHRASE
  PARSING_ARTIFACT
  BRAND_NAME
  REDUNDANT_WORDS
}

enum PatternSource {
  AI_LEARNED
  MANUAL
  AUTO_DETECTED
  USER_FEEDBACK
}

// ============================================================================
// AI-Validated Mapping Tables
// ============================================================================

model ValidatedMapping {
  id                      String   @id @default(cuid())
  rawIngredient           String
  normalizedForm          String
  foodId                  String
  foodName                String
  brandName               String?
  source                  String   @default("fatsecret")
  aiConfidence            Float
  validationReason        String?
  isAlias                 Boolean  @default(false)
  canonicalRawIngredient  String?
  validatedAt             DateTime @default(now())
  validatedBy             String   @default("ai")
  usedCount               Int      @default(0)
  lastUsedAt              DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([rawIngredient, source])
  @@unique([normalizedForm, source], map: "ValidatedMapping_normalizedForm_source_key")
  @@index([rawIngredient])
  @@index([normalizedForm])
  @@index([isAlias, canonicalRawIngredient])
  @@index([foodId])
  @@index([lastUsedAt(sort: Desc)])
}

model MappingValidationFailure {
  id                      String   @id @default(cuid())
  rawIngredient           String
  attemptedFoodId         String
  attemptedFoodName       String
  ourConfidence           Float
  aiConfidence            Float
  aiRejectionReason       String
  aiFailureCategory       String
  failureType             String
  aiSuggestedAlternative  String?
  retrySucceeded          Boolean?
  scoringDetails          Json?
  createdAt               DateTime @default(now())

  @@index([aiFailureCategory])
  @@index([failureType])
  @@index([rawIngredient])
  @@index([createdAt(sort: Desc)])
}

model AiNormalizeCache {
  normalizedKey            String   @id   // Normalized ingredient name for lookup (computed from rawLine)
  rawLine                  String?        // Original raw line (for reference/debugging only)
  normalizedName           String
  canonicalBase            String?              // Base ingredient for cache lookup (e.g., 'strawberries' for 'strawberry halves')
  synonyms                 Json     @default("[]")
  prepPhrases              Json     @default("[]")
  sizePhrases              Json     @default("[]")
  cookingModifier          String?              // Preserved for future food diary use
  estimatedCaloriesPer100g Float?               // AI estimate (kcal)
  estimatedProteinPer100g  Float?               // AI estimate (g)
  estimatedCarbsPer100g    Float?               // AI estimate (g)
  estimatedFatPer100g      Float?               // AI estimate (g)
  nutritionConfidence      Float?               // 0-1 confidence for nutrition estimate
  isBranded                Boolean  @default(false)  // Whether the AI identified this as a branded product
  createdAt                DateTime @default(now())
  lastUsedAt               DateTime @default(now())
  useCount                 Int      @default(0)

  @@index([lastUsedAt(sort: Desc)])
}

// ============================================================================
// OpenFoodFacts Cache Tables
// ============================================================================

/// OpenFoodFacts product cache
/// ID format: "off_<barcode>" (e.g., "off_021130126026")
/// Source: https://world.openfoodfacts.org — free, no API key required
model OpenFoodFactsCache {
  id               String                      @id         // "off_<barcode>"
  barcode          String                      @unique
  name             String
  brandName        String?
  nutrientsPer100g Json?                                   // { calories, protein, carbs, fat, fiber, sugars, sodium }
  servingSize      String?                                 // Raw string from OFF label, e.g., "1 container (170g)"
  servingGrams     Float?                                  // Primary parsed gram weight for default serving
  syncedAt         DateTime                    @default(now())
  expiresAt        DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  servings         OpenFoodFactsServingCache[]

  @@index([syncedAt])
  @@index([name])
  @@index([brandName])
}

/// AI-estimated or label-derived serving weights for OFF products
/// Mirrors FdcServingCache structure exactly
model OpenFoodFactsServingCache {
  id                Int                    @id @default(autoincrement())
  offId             String                                 // FK to OpenFoodFactsCache.id
  description       String                                 // e.g., "1 cup", "1 container"
  grams             Float
  volumeMl          Float?
  derivedViaDensity Boolean                @default(false)
  densityGml        Float?
  prepModifier      String?                                // e.g., "chopped", "minced"
  source            String                 @default("openfoodfacts")
  isAiEstimated     Boolean                @default(false)
  confidence        Float?
  note              String?
  food              OpenFoodFactsCache     @relation(fields: [offId], references: [id], onDelete: Cascade)

  @@unique([offId, description])
  @@index([offId])
  @@index([prepModifier])
}

/// Tracks search query patterns that AI identifies as problematic
/// Used to improve parser and search logic based on AI feedback
model SearchQueryPattern {
  id               String   @id @default(cuid())
  rawIngredient    String   // Original ingredient line
  searchQuery      String   // The query that was used
  suggestedQuery   String?  // AI's suggested alternative 
  detectedIssues   Json     @default("[]") // Array of issue types
  aiReason         String   // AI's explanation
  aiCategory       String   // validation category: search_query_issue, search_scoring_issue, etc.
  occurrences      Int      @default(1) // How many times we've seen this pattern
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([searchQuery, aiCategory])
  @@index([aiCategory])
  @@index([occurrences(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

/// Learned synonym pairs from AI normalization
/// Used to speed up future lookups by caching synonym relationships
model LearnedSynonym {
  id           String   @id @default(cuid())
  sourceTerm   String   // The original term
  targetTerm   String   // The synonym
  locale       String?  @db.VarChar(16)
  category     String?  // e.g., "british_american", "spelling", "ingredient"
  source       String   @default("ai") // "ai", "manual", "fatsecret_alias"
  confidence   Float    @default(0.8)
  useCount     Int      @default(0)
  successCount Int      @default(0)
  failureCount Int      @default(0)
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())

  @@unique([sourceTerm, targetTerm])
  @@index([sourceTerm])
  @@index([successCount(sort: Desc)])
}

// ============================================================================
// AI-Generated Nutrition Data
// ============================================================================

model AiGeneratedFood {
  id                    String    @id @default(cuid())
  ingredientName        String    @unique  // Normalized ingredient (cache key)
  rawLine               String?             // Original raw line for reference
  displayName           String              // Human-readable food name

  // Nutrition per 100g
  caloriesPer100g       Float
  proteinPer100g        Float
  carbsPer100g          Float
  fatPer100g            Float
  fiberPer100g          Float?    @default(0)
  sugarPer100g          Float?    @default(0)
  sodiumMgPer100g       Float?    @default(0)
  saturatedFatPer100g   Float?    @default(0)
  cholesterolMgPer100g  Float?    @default(0)

  // AI metadata
  aiConfidence          Float               // Self-assessed 0-1
  aiModel               String              // e.g., "google/gemini-2.0-flash"
  aiNotes               String?             // Caveats from the AI
  baseFoodName          String?             // Reference food used (e.g., "salad seasoning")
  baseFoodSource        String?             // "fatsecret" | "fdc" | null

  // Lifecycle
  reviewStatus          String    @default("pending")  // "pending" | "approved" | "rejected"
  expiresAt             DateTime?           // Optional, for scheduled re-evaluation
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  useCount              Int       @default(0)

  servings              AiGeneratedServing[]
  ingredientMaps        IngredientFoodMap[]

  @@index([ingredientName])
  @@index([reviewStatus])
  @@index([createdAt(sort: Desc)])
}

model AiGeneratedServing {
  id                String          @id @default(cuid())
  foodId            String
  label             String              // e.g., "cup", "tbsp", "packet"
  grams             Float               // Estimated weight
  volumeMl          Float?              // For volume units
  aiConfidence      Float
  aiNotes           String?
  createdAt         DateTime        @default(now())
  food              AiGeneratedFood @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([foodId, label])
  @@index([foodId])
}

model DailyLog {
  id            String     @id @default(cuid())
  userId        String
  date          String     // YYYY-MM-DD
  calorieTarget Int        @default(2000)
  proteinTarget Float      @default(150)
  carbsTarget   Float      @default(200)
  fatTarget     Float      @default(65)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  entries       LogEntry[]

  @@unique([userId, date])
  @@index([userId, date])
}

model LogEntry {
  id          String    @id @default(cuid())
  dailyLogId  String
  mealType    String    // "breakfast" | "lunch" | "dinner" | "snack"
  foodId      String?   // Reference to Food (if mapped)
  foodName    String    // Raw or mapped name
  brandName   String?   // Brand name
  servingSize String    // e.g. "1 cup" or "100g"
  quantity    Float     // Multiplier (e.g. 1.5)
  grams       Float     // Total weight in grams
  calories    Float     // Total calories for this entry
  protein     Float     // Total protein
  carbs       Float     // Total carbs
  fat         Float     // Total fat
  loggedAt    DateTime  @default(now())
  dailyLog    DailyLog  @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  food        Food?     @relation(fields: [foodId], references: [id], onDelete: SetNull)

  @@index([dailyLogId])
  @@index([foodId])
}
