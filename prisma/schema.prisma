generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                @id
  email                String                @unique
  name                 String?
  role                 String                @default("user")
  createdAt            DateTime              @default(now())
  avatarUrl            String?
  avatarKey            String?
  firstName            String?
  lastName             String?
  username             String?               @unique
  displayName          String?
  bio                  String?
  collections          Collection[]
  comments             Comment[]
  following            Follow[]              @relation("Following")
  followedBy           Follow[]              @relation("FollowedBy")
  likes                Like[]
  notificationsActed   Notification[]        @relation("NotificationActor")
  notifications        Notification[]        @relation("NotificationUser")
  recipes              Recipe[]
  recipeViews          RecipeView[]
  userPortionOverrides UserPortionOverride[]
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Recipe {
  id            String                   @id @default(cuid())
  authorId      String
  title         String
  bodyMd        String
  servings      Int                      @default(1)
  prepTime      String?
  parentId      String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  collections   CollectionRecipe[]
  comments      Comment[]
  ingredients   Ingredient[]
  likes         Like[]
  notifications Notification[]
  nutrition     Nutrition?
  photos        Photo[]
  author        User                     @relation(fields: [authorId], references: [id])
  parent        Recipe?                  @relation("Forks", fields: [parentId], references: [id])
  forks         Recipe[]                 @relation("Forks")
  features      RecipeFeatureLite?
  interactions  RecipeInteractionDaily[]
  similarTo     RecipeSimilar[]          @relation("RecipeToSimilar")
  similarFrom   RecipeSimilar[]          @relation("RecipeIsSimilar")
  tags          RecipeTag[]
  views         RecipeView[]

  @@index([createdAt])
}

model Ingredient {
  id       String              @id @default(cuid())
  recipeId String
  name     String
  qty      Float
  unit     String
  recipe   Recipe              @relation(fields: [recipeId], references: [id])
  foodMaps IngredientFoodMap[]
}

model Nutrition {
  recipeId    String   @id
  calories    Int
  proteinG    Float
  carbsG      Float
  fatG        Float
  fiberG      Float?   @default(0)
  sugarG      Float?   @default(0)
  healthScore Float?   @default(0)
  goal        String?  @default("general")
  computedAt  DateTime @default(now())
  recipe      Recipe   @relation(fields: [recipeId], references: [id])
}

model Photo {
  id          String  @id @default(cuid())
  recipeId    String
  s3Key       String
  width       Int
  height      Int
  isMainPhoto Boolean @default(false)
  recipe      Recipe  @relation(fields: [recipeId], references: [id])

  @@index([recipeId, isMainPhoto])
}

model Tag {
  id        String       @id @default(cuid())
  slug      String       @unique
  label     String
  namespace TagNamespace
  createdAt DateTime     @default(now())
  recipes   RecipeTag[]
}

model RecipeTag {
  recipeId   String
  tagId      String
  source     TagSource @default(USER)
  confidence Float     @default(1.0)
  recipe     Recipe    @relation(fields: [recipeId], references: [id])
  tag        Tag       @relation(fields: [tagId], references: [id])

  @@id([recipeId, tagId])
  @@index([tagId])
}

model Comment {
  id            String         @id @default(cuid())
  recipeId      String
  userId        String
  body          String
  createdAt     DateTime       @default(now())
  recipe        Recipe         @relation(fields: [recipeId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  notifications Notification[]
}

model Like {
  userId    String
  recipeId  String
  createdAt DateTime @default(now())
  recipe    Recipe   @relation(fields: [recipeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, recipeId])
}

model Collection {
  id        String             @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id])
  recipes   CollectionRecipe[]

  @@unique([userId, name])
}

model CollectionRecipe {
  collectionId String
  recipeId     String
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id])
  recipe       Recipe     @relation(fields: [recipeId], references: [id])

  @@id([collectionId, recipeId])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowedBy", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  actorId   String
  type      String
  recipeId  String?
  commentId String?
  createdAt DateTime  @default(now())
  readAt    DateTime?
  bumpedAt  DateTime  @default(now())
  actor     User      @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  comment   Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  recipe    Recipe?   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user      User      @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, actorId, type], map: "uniq_follow")
  @@unique([userId, actorId, type, recipeId], map: "uniq_like")
  @@unique([userId, type, commentId], map: "uniq_comment")
  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([userId, bumpedAt])
}

model Food {
  id                   String                @id @default(cuid())
  name                 String
  brand                String?               @db.VarChar(120)
  categoryId           String?
  source               String                @default("usda")
  verification         String                @default("unverified")
  densityGml           Float?
  kcal100              Float
  protein100           Float
  carbs100             Float
  fat100               Float
  fiber100             Float?
  sugar100             Float?
  popularity           Int                   @default(0)
  createdById          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  barcodes             Barcode[]
  aliases              FoodAlias[]
  units                FoodUnit[]
  ingredientMaps       IngredientFoodMap[]
  portionOverrides     PortionOverride[]
  userPortionOverrides UserPortionOverride[]

  @@unique([name, brand])
  @@index([name])
  @@index([brand])
  @@index([source])
  @@index([verification])
  @@index([categoryId])
  @@index([createdAt])
  @@index([popularity])
  @@index([verification, source])
  @@index([categoryId, verification])
}

model FdcFoodCache {
  id            Int                  @id
  description   String
  brandName     String?
  dataType      String
  nutrients     Json                 // nutrientsPer100g
  servingSize   Float?
  servingSizeUnit String?
  syncedAt      DateTime             @default(now())
  expiresAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  servings      FdcServingCache[]
  
  @@index([syncedAt])
  @@index([expiresAt])
}

model FdcServingCache {
  id                Int            @id @default(autoincrement())
  fdcId             Int
  description       String
  grams             Float
  source            String         @default("fdc")
  isAiEstimated     Boolean        @default(false)
  food              FdcFoodCache   @relation(fields: [fdcId], references: [id], onDelete: Cascade)
  
  @@index([fdcId])
}

model FatSecretFoodCache {
  id               String                     @id
  name             String
  brandName        String?
  foodType         String?
  country          String?
  description      String?
  defaultServingId String?
  source           String?                    @default("food.get.v4")
  confidence       Float?                     @default(0.9)
  nutrientsPer100g Json?
  legacyFoodId     String?                    @unique
  hash             String?
  syncedAt         DateTime                   @default(now())
  expiresAt        DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  densityEstimates FatSecretDensityEstimate[]
  aliases          FatSecretFoodAlias[]
  servings         FatSecretServingCache[]

  @@index([syncedAt])
  @@index([expiresAt])
  @@index([hash])
}

model FatSecretServingCache {
  id                     String                    @id
  foodId                 String
  measurementDescription String?
  numberOfUnits          Float?
  metricServingAmount    Float?
  metricServingUnit      String?
  servingWeightGrams     Float?
  volumeMl               Float?
  isVolume               Boolean                   @default(false)
  isDefault              Boolean                   @default(false)
  derivedViaDensity      Boolean                   @default(false)
  densityEstimateId      String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  source                 String?                   @default("fatsecret")
  confidence             Float?
  note                   String?
  densityEstimate        FatSecretDensityEstimate? @relation(fields: [densityEstimateId], references: [id])
  food                   FatSecretFoodCache        @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@index([foodId])
  @@index([isDefault])
  @@index([densityEstimateId])
}

model FatSecretFoodAlias {
  id        String             @id @default(cuid())
  foodId    String
  alias     String
  locale    String?            @db.VarChar(16)
  source    String?            @default("fatsecret")
  createdAt DateTime           @default(now())
  food      FatSecretFoodCache @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([foodId, alias])
  @@index([alias])
}

model FatSecretDensityEstimate {
  id         String                  @id @default(cuid())
  foodId     String
  densityGml Float
  source     String
  confidence Float?                  @default(0)
  notes      String?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  food       FatSecretFoodCache      @relation(fields: [foodId], references: [id], onDelete: Cascade)
  servings   FatSecretServingCache[]

  @@index([foodId])
  @@index([source])
}

model FatSecretCacheSyncRun {
  id             String    @id @default(cuid())
  status         String    @default("pending")
  totalRequested Int       @default(0)
  totalHydrated  Int       @default(0)
  totalFailed    Int       @default(0)
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  error          String?
  metadata       Json?

  @@index([status, startedAt])
}

model FoodUnit {
  id     String @id @default(cuid())
  foodId String
  label  String
  grams  Float
  Food   Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)
}

model Barcode {
  id     String @id @default(cuid())
  gtin   String @unique
  foodId String
  Food   Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)
}

model IngredientFoodMap {
  id           String     @id @default(cuid())
  ingredientId String
  foodId       String?
  fatsecretFoodId       String?
  fatsecretServingId    String?
  fatsecretGrams        Float?
  fatsecretConfidence   Float?
  fatsecretSource       String?
  pendingVolume         Boolean   @default(false)
  mappedBy     String
  confidence   Float      @default(0.0)
  useOnce      Boolean    @default(false)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  food         Food?      @relation(fields: [foodId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
  @@index([foodId])
  @@index([fatsecretFoodId])
}

model FoodAlias {
  id     String @id @default(cuid())
  foodId String
  alias  String
  food   Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([foodId, alias])
  @@index([foodId])
  @@index([alias])
}

model PortionOverride {
  id        String   @id @default(cuid())
  foodId    String
  unit      String
  grams     Float
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([foodId, unit])
  @@index([unit])
}

model UserPortionOverride {
  id        String   @id @default(cuid())
  userId    String
  foodId    String
  unit      String
  grams     Float
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, foodId, unit])
  @@index([userId, foodId])
}

model RecipeFeatureLite {
  recipeId          String   @id
  proteinPer100kcal Float    @default(0)
  carbPer100kcal    Float    @default(0)
  fatPer100kcal     Float    @default(0)
  fiberPerServing   Float    @default(0)
  sugarPerServing   Float    @default(0)
  kcalPerServing    Float    @default(0)
  ingredientCount   Int      @default(0)
  goalScores        String   @default("{}")
  methodFlags       String   @default("[]")
  cuisineScores     String   @default("{}")
  updatedAt         DateTime @updatedAt
  recipe            Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model RecipeView {
  id        String   @id @default(cuid())
  recipeId  String
  userId    String?
  sessionId String
  createdAt DateTime @default(now())
  recipe    Recipe   @relation(fields: [recipeId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([recipeId, createdAt])
  @@index([sessionId, createdAt])
}

model RecipeInteractionDaily {
  id       String   @id @default(cuid())
  recipeId String
  day      DateTime
  views    Int      @default(0)
  likes    Int      @default(0)
  comments Int      @default(0)
  saves    Int      @default(0)
  score    Float    @default(0)
  recipe   Recipe   @relation(fields: [recipeId], references: [id])

  @@unique([recipeId, day])
  @@index([score])
}

model RecipeSimilar {
  recipeId  String
  similarId String
  score     Float
  updatedAt DateTime @updatedAt
  recipe    Recipe   @relation("RecipeToSimilar", fields: [recipeId], references: [id])
  similar   Recipe   @relation("RecipeIsSimilar", fields: [similarId], references: [id])

  @@id([recipeId, similarId])
  @@index([recipeId, score])
  @@index([similarId])
}

enum TagNamespace {
  MEAL_TYPE
  CUISINE
  DIET
  METHOD
  COURSE
  TIME
  DIFFICULTY
  OCCASION
  GOAL
}

enum TagSource {
  USER
  AUTO_CONFIDENT
  AUTO_SUGGESTED
}

model GlobalIngredientMapping {
  id                  String   @id @default(cuid())
  normalizedName      String   @unique
  fatsecretFoodId     String?
  fatsecretServingId  String?
  fdcId               Int?
  source              String   // "fatsecret" | "fdc"
  confidence          Float
  usageCount          Int      @default(1)
  lastUsed            DateTime @default(now())
  createdBy           String?
  isUserOverride      Boolean  @default(false)
  createdAt           DateTime @default(now())
  
  @@index([normalizedName])
  @@index([confidence])
}

model IngredientCleanupPattern {
  id            String   @id @default(cuid())
  
  // Pattern definition
  pattern       String   @unique
  patternType   PatternType
  replacement   String
  description   String?
  
  // Learning metadata
  source        PatternSource
  confidence    Float    @default(0.8)
  
  // Usage tracking
  usageCount    Int      @default(0)
  successCount  Int      @default(0)
  failureCount  Int      @default(0)
  
  // Computed metrics
  successRate   Float?
  
  // Timestamps
  createdAt     DateTime @default(now())
  lastUsed      DateTime @default(now())
  
  // Relations
  appliedTo     IngredientCleanupApplication[]
  
  @@index([patternType])
  @@index([source])
  @@index([confidence])
  @@index([successRate])
}

model IngredientCleanupApplication {
  id               String   @id @default(cuid())
  
  // What was cleaned
  rawInput         String
  cleanedOutput    String
  
  // Which pattern was used
  patternId        String
  pattern          IngredientCleanupPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)
  
  // Context
  recipeId         String?
  ingredientId     String?
  
  // Outcome
  mappingSucceeded Boolean?
  confidenceScore  Float?
  
  // Timestamp
  appliedAt        DateTime @default(now())
  
  @@index([patternId])
  @@index([mappingSucceeded])
  @@index([appliedAt])
}

enum PatternType {
  MEASUREMENT_PREFIX
  MEASUREMENT_SUFFIX
  PREP_PHRASE
  SIZE_PHRASE
  PARSING_ARTIFACT
  BRAND_NAME
  REDUNDANT_WORDS
}

enum PatternSource {
  AI_LEARNED
  MANUAL
  AUTO_DETECTED
  USER_FEEDBACK
}

// ============================================================================
// AI-Validated Mapping Tables
// ============================================================================

model ValidatedMapping {
  id                      String   @id @default(cuid())
  rawIngredient           String
  normalizedForm          String
  foodId                  String
  foodName                String
  brandName               String?
  source                  String   @default("fatsecret")
  aiConfidence            Float
  validationReason        String?
  isAlias                 Boolean  @default(false)
  canonicalRawIngredient  String?
  validatedAt             DateTime @default(now())
  validatedBy             String   @default("ai")
  usedCount               Int      @default(0)
  lastUsedAt              DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([rawIngredient, source])
  @@unique([normalizedForm, source], map: "ValidatedMapping_normalizedForm_source_key")
  @@index([rawIngredient])
  @@index([normalizedForm])
  @@index([isAlias, canonicalRawIngredient])
  @@index([foodId])
  @@index([lastUsedAt(sort: Desc)])
}

model MappingValidationFailure {
  id                      String   @id @default(cuid())
  rawIngredient           String
  attemptedFoodId         String
  attemptedFoodName       String
  ourConfidence           Float
  aiConfidence            Float
  aiRejectionReason       String
  aiFailureCategory       String
  failureType             String
  aiSuggestedAlternative  String?
  retrySucceeded          Boolean?
  scoringDetails          Json?
  createdAt               DateTime @default(now())

  @@index([aiFailureCategory])
  @@index([failureType])
  @@index([rawIngredient])
  @@index([createdAt(sort: Desc)])
}

model AiNormalizeCache {
  rawLine                  String   @id
  normalizedName           String
  synonyms                 Json     @default("[]")
  prepPhrases              Json     @default("[]")
  sizePhrases              Json     @default("[]")
  cookingModifier          String?              // Preserved for future food diary use
  estimatedCaloriesPer100g Float?               // AI estimate (kcal)
  estimatedProteinPer100g  Float?               // AI estimate (g)
  estimatedCarbsPer100g    Float?               // AI estimate (g)
  estimatedFatPer100g      Float?               // AI estimate (g)
  nutritionConfidence      Float?               // 0-1 confidence for nutrition estimate
  createdAt                DateTime @default(now())
  lastUsedAt               DateTime @default(now())
  useCount                 Int      @default(0)

  @@index([lastUsedAt(sort: Desc)])
}

/// Tracks search query patterns that AI identifies as problematic
/// Used to improve parser and search logic based on AI feedback
model SearchQueryPattern {
  id               String   @id @default(cuid())
  rawIngredient    String   // Original ingredient line
  searchQuery      String   // The query that was used
  suggestedQuery   String?  // AI's suggested alternative 
  detectedIssues   Json     @default("[]") // Array of issue types
  aiReason         String   // AI's explanation
  aiCategory       String   // validation category: search_query_issue, search_scoring_issue, etc.
  occurrences      Int      @default(1) // How many times we've seen this pattern
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([searchQuery, aiCategory])
  @@index([aiCategory])
  @@index([occurrences(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

/// Learned synonym pairs from AI normalization
/// Used to speed up future lookups by caching synonym relationships
model LearnedSynonym {
  id           String   @id @default(cuid())
  sourceTerm   String   // The original term
  targetTerm   String   // The synonym
  locale       String?  @db.VarChar(16)
  category     String?  // e.g., "british_american", "spelling", "ingredient"
  source       String   @default("ai") // "ai", "manual", "fatsecret_alias"
  confidence   Float    @default(0.8)
  useCount     Int      @default(0)
  successCount Int      @default(0)
  failureCount Int      @default(0)
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())

  @@unique([sourceTerm, targetTerm])
  @@index([sourceTerm])
  @@index([successCount(sort: Desc)])
}
