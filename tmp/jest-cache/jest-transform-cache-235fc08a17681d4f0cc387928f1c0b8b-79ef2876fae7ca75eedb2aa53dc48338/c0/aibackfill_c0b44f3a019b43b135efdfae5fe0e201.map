import crypto from 'node:crypto';
import { prisma } from '../db';
import { logger } from '../logger';
import { requestAiServing, type ServingGapType } from '../ai/serving-estimator';
import { tryServingFromSimilarFoods } from '../ai/similar-serving-lookup';
import {
    FATSECRET_CACHE_AI_MAX_DENSITY,
    FATSECRET_CACHE_AI_MIN_DENSITY,
} from './config';

const VOLUME_UNIT_TO_ML: Record<string, number> = {
    ml: 1,
    milliliter: 1,
    milliliters: 1,
    millilitre: 1,
    millilitres: 1,
    l: 1000,
    liter: 1000,
    liters: 1000,
    litre: 1000,
    litres: 1000,
    cup: 240,
    cups: 240,
    tbsp: 15,
    tablespoon: 15,
    tablespoons: 15,
    tsp: 5,
    teaspoon: 5,
    teaspoons: 5,
    floz: 30,
    'fl oz': 30,
    'fluid ounce': 30,
    'fluid ounces': 30,
};

const COUNT_UNITS = new Set(['count', 'item', 'items', 'piece', 'pieces', 'tortilla', 'egg', 'bagel', 'slice', 'slices']);

function convertVolumeToMl(unit: string, amount: number): number | null {
    if (!unit || !Number.isFinite(amount) || amount <= 0) return null;
    const normalized = unit.trim().toLowerCase();
    const scale = VOLUME_UNIT_TO_ML[normalized];
    if (!scale) return null;
    return amount * scale;
}

function buildServingId(foodId: string, label: string): string {
    const hash = crypto.createHash('sha1').update(`${foodId}:${label}`).digest('hex').slice(0, 12);
    return `ai_${hash}`;
}

export interface InsertAiServingOptions {
    dryRun?: boolean;
    promptDebug?: boolean;
    targetServingUnit?: string;  // e.g., "slice" - for cross-reference lookup
}

export async function insertAiServing(
    foodId: string,
    gapType: ServingGapType,
    options: InsertAiServingOptions = {}
): Promise<{ success: boolean; reason?: string }> {
    const food = await prisma.fatSecretFoodCache.findUnique({
        where: { id: foodId },
        include: { servings: true },
    });

    if (!food) {
        logger.warn('FatSecret food missing from cache', { foodId });
        return { success: false, reason: 'food_missing' };
    }

    // ============================================================
    // PHASE 1: Try cross-reference lookup from similar foods first
    // ============================================================
    if (options.targetServingUnit) {
        const similarResult = await tryServingFromSimilarFoods(
            foodId,
            food.name,
            options.targetServingUnit,
            0.7  // Minimum confidence threshold
        );

        if (similarResult.success && similarResult.grams) {
            // Found matching serving from similar foods - use it directly!
            const servingLabel = `1 ${options.targetServingUnit}`;
            const servingId = buildServingId(foodId, servingLabel);

            logger.info("AI prompt constructed", {
                foodId,
                foodName: food.name,
                servingUnit: options.targetServingUnit,
                grams: similarResult.grams,
                confidence: similarResult.confidence,
                matchCount: similarResult.matches?.length || 0,
            });

            if (!options.dryRun) {
                await prisma.fatSecretServingCache.upsert({
                    where: { id: servingId },
                    create: {
                        id: servingId,
                        foodId,
                        measurementDescription: servingLabel,
                        numberOfUnits: 1,
                        metricServingAmount: similarResult.grams,
                        metricServingUnit: options.targetServingUnit,
                        servingWeightGrams: similarResult.grams,
                        isVolume: false,
                        isDefault: false,
                        derivedViaDensity: false,
                        source: 'cross_reference',
                        confidence: similarResult.confidence,
                        note: `Avg from ${similarResult.matches?.length || 0} similar foods`,
                    },
                    update: {
                        servingWeightGrams: similarResult.grams,
                        confidence: similarResult.confidence,
                        note: `Avg from ${similarResult.matches?.length || 0} similar foods`,
                    },
                });
            }

            return { success: true };
        }
    }

    // ============================================================
    // PHASE 2: Fall back to AI if cross-reference didn't work
    // Pass any similar foods data we found as context to help AI
    // ============================================================

    // Convert any found matches to AI context format
    const similarFoodsContext = options.targetServingUnit
        ? await (async () => {
            const { findSimilarServings } = await import('../ai/similar-serving-lookup');
            const result = await findSimilarServings(food.name, options.targetServingUnit!, foodId);
            if (result.found && result.matches.length > 0) {
                return result.matches.map(m => ({
                    foodName: m.foodName,
                    servingDescription: m.servingDescription,
                    grams: m.grams,
                }));
            }
            return undefined;
        })()
        : undefined;

    const aiResult = await requestAiServing({
        gapType,
        food,
        targetServingUnit: options.targetServingUnit,
        similarFoods: similarFoodsContext,
    });

    if (options.promptDebug) {
        logger.info(
            'AI prompt debug',
            { foodId, gapType, prompt: aiResult.prompt },
        );
        logger.info(
            'AI response debug',
            { foodId, gapType, raw: aiResult.raw, suggestion: aiResult.status === 'success' ? aiResult.suggestion : undefined },
        );
    }

    if (aiResult.status === 'error') {
        logger.warn('AI serving suggestion failed', { foodId, reason: aiResult.reason });
        return { success: false, reason: aiResult.reason };
    }

    const suggestion = aiResult.suggestion;
    let volumeMl =
        suggestion.volumeUnit && suggestion.volumeAmount
            ? convertVolumeToMl(suggestion.volumeUnit, suggestion.volumeAmount)
            : null;

    let countServing = false;
    let countUnit: string | undefined;

    if (gapType === 'volume' && !volumeMl) {
        const unit = suggestion.volumeUnit?.toLowerCase().trim();
        if (suggestion.volumeAmount && suggestion.volumeAmount > 0 && (unit ? COUNT_UNITS.has(unit) : true)) {
            countServing = true;
            countUnit = unit ?? 'count';
            volumeMl = suggestion.volumeAmount;
        } else if (unit && COUNT_UNITS.has(unit)) {
            countServing = true;
            countUnit = unit;
            volumeMl = suggestion.volumeAmount ?? 1;
        }
    }

    if (gapType === 'volume' && !volumeMl && !countServing) {
        logger.warn(
            'AI did not return a convertible volume',
            { foodId, serving: suggestion.servingLabel },
        );
        return { success: false, reason: 'missing_volume_unit' };
    }

    if (suggestion.grams <= 0) {
        logger.warn('AI returned invalid gram weight', { foodId });
        return { success: false, reason: 'invalid_grams' };
    }

    const density = volumeMl && !countServing ? suggestion.grams / volumeMl : null;
    if (
        density &&
        (density < FATSECRET_CACHE_AI_MIN_DENSITY || density > FATSECRET_CACHE_AI_MAX_DENSITY)
    ) {
        logger.warn('AI density outside bounds', { foodId, density });
        return { success: false, reason: 'density_outside_bounds' };
    }

    const servingId = buildServingId(foodId, suggestion.servingLabel);

    if (options.dryRun) {
        logger.info(
            'DRY RUN: would insert AI-derived serving',
            {
                foodId,
                gapType,
                servingId,
                label: suggestion.servingLabel,
                grams: suggestion.grams,
                volumeMl,
                confidence: suggestion.confidence,
            }
        );
        return { success: true };
    }

    let densityEstimateId: string | undefined;
    await prisma.$transaction(async (tx) => {
        if (density && volumeMl) {
            const densityRow = await tx.fatSecretDensityEstimate.create({
                data: {
                    foodId,
                    densityGml: density,
                    source: 'ai',
                    confidence: suggestion.confidence,
                    notes: suggestion.rationale,
                },
            });
            densityEstimateId = densityRow.id;
        }

        await tx.fatSecretServingCache.upsert({
            where: { id: servingId },
            create: {
                id: servingId,
                foodId,
                measurementDescription: suggestion.servingLabel,
                numberOfUnits: suggestion.volumeAmount ?? (countServing ? 1 : undefined),
                metricServingAmount: volumeMl ?? suggestion.grams,
                metricServingUnit: countServing ? (countUnit ?? suggestion.volumeUnit ?? 'count') : volumeMl ? 'ml' : 'g',
                servingWeightGrams: suggestion.grams,
                volumeMl,
                isVolume: gapType === 'volume',
                isDefault: false,
                derivedViaDensity: volumeMl != null && !countServing,
                densityEstimateId,
                source: 'ai',
                confidence: suggestion.confidence,
                note: suggestion.rationale,
            },
            update: {
                measurementDescription: suggestion.servingLabel,
                numberOfUnits: suggestion.volumeAmount ?? (countServing ? 1 : undefined),
                metricServingAmount: volumeMl ?? suggestion.grams,
                metricServingUnit: countServing ? (countUnit ?? suggestion.volumeUnit ?? 'count') : volumeMl ? 'ml' : 'g',
                servingWeightGrams: suggestion.grams,
                volumeMl,
                isVolume: gapType === 'volume',
                derivedViaDensity: volumeMl != null && !countServing,
                densityEstimateId,
                source: 'ai',
                confidence: suggestion.confidence,
                note: suggestion.rationale,
            },
        });
    });

    logger.info(
        'Inserted AI-derived FatSecret serving',
        { foodId, servingId, gapType, label: suggestion.servingLabel },
    );

    return { success: true };
}

// ============================================================
// Size Qualifier Servings (small/medium/large) for FatSecret
// ============================================================

import { requestSizeEstimates, type SizeEstimates } from '../ai/serving-estimator';

const SIZE_QUALIFIERS = ['small', 'medium', 'large'] as const;
export type SizeQualifier = typeof SIZE_QUALIFIERS[number];

/**
 * Check if a unit string is a size qualifier
 */
export function isSizeQualifier(unit: string | undefined): unit is SizeQualifier {
    if (!unit) return false;
    return SIZE_QUALIFIERS.includes(unit.toLowerCase() as SizeQualifier);
}

/**
 * Get cached size servings for a FatSecret food.
 * Returns null if no size servings exist.
 */
export async function getCachedFatSecretSizeServings(foodId: string): Promise<{
    small: number;
    medium: number;
    large: number;
} | null> {
    const servings = await prisma.fatSecretServingCache.findMany({
        where: {
            foodId,
            OR: [
                { measurementDescription: { contains: 'small', mode: 'insensitive' } },
                { measurementDescription: { contains: 'medium', mode: 'insensitive' } },
                { measurementDescription: { contains: 'large', mode: 'insensitive' } },
            ],
            source: 'ai',
        },
    });

    if (servings.length < 3) return null;

    const result: { small?: number; medium?: number; large?: number } = {};
    for (const s of servings) {
        const desc = (s.measurementDescription || '').toLowerCase();
        const grams = s.servingWeightGrams;
        if (!grams) continue;

        if (desc.includes('small') && !desc.includes('large')) result.small = grams;
        else if (desc.includes('medium')) result.medium = grams;
        else if (desc.includes('large')) result.large = grams;
    }

    if (result.small && result.medium && result.large) {
        return result as { small: number; medium: number; large: number };
    }
    return null;
}

/**
 * Insert size servings into FatSecretServingCache.
 * Creates 3 servings: "1 small", "1 medium", "1 large" with their estimated weights.
 */
export async function insertFatSecretSizeServings(
    foodId: string,
    sizes: SizeEstimates
): Promise<{ success: boolean; reason?: string }> {
    try {
        const servingsToCreate = [
            { label: '1 small', grams: sizes.small },
            { label: '1 medium', grams: sizes.medium },
            { label: '1 large', grams: sizes.large },
        ];

        await prisma.$transaction(
            servingsToCreate.map(({ label, grams }) =>
                prisma.fatSecretServingCache.create({
                    data: {
                        id: buildServingId(foodId, label),
                        foodId,
                        measurementDescription: label,
                        numberOfUnits: 1,
                        metricServingAmount: grams,
                        metricServingUnit: 'g',
                        servingWeightGrams: grams,
                        isVolume: false,
                        isDefault: false,
                        derivedViaDensity: false,
                        source: 'ai',
                        confidence: sizes.confidence,
                        note: sizes.rationale,
                    },
                })
            )
        );

        logger.info(
            'Inserted FatSecret size servings',
            { foodId, small: sizes.small, medium: sizes.medium, large: sizes.large },
        );

        return { success: true };
    } catch (error) {
        logger.warn(
            'Failed to insert FatSecret size servings',
            { foodId, error: (error as Error).message },
        );
        return { success: false, reason: (error as Error).message };
    }
}

/**
 * Get or create size servings for a FatSecret food.
 * Checks cache first, then triggers AI if needed.
 */
export async function getOrCreateFatSecretSizeServings(
    foodId: string,
    foodName: string
): Promise<{ small: number; medium: number; large: number } | null> {
    // Check cache first
    const cached = await getCachedFatSecretSizeServings(foodId);
    if (cached) {
        logger.debug('Using cached FatSecret size servings', { foodId, cached: true });
        return cached;
    }

    // Request from AI
    const result = await requestSizeEstimates(foodName, 'fatsecret');
    if (result.status === 'error') {
        logger.warn('AI size estimate failed for FatSecret', { foodId, reason: result.reason });
        return null;
    }

    // Cache for future use
    await insertFatSecretSizeServings(foodId, result.sizes);

    return {
        small: result.sizes.small,
        medium: result.sizes.medium,
        large: result.sizes.large,
    };
}
