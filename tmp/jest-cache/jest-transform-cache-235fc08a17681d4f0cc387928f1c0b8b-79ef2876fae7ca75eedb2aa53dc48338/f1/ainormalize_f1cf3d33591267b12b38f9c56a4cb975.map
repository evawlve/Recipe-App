import 'dotenv/config';
import {
  FATSECRET_CACHE_AI_MODEL,
  OPENAI_API_BASE_URL,
} from './config';
import { getAiNormalizeCache, saveAiNormalizeCache, learnFromAiResponse, type AiNormalizeResult } from './validated-mapping-helpers';
import { applySynonyms } from './normalization-rules';

const OPENAI_API_KEY = process.env.OPENAI_API_KEY ?? '';

type AiNormalizeSuccess = {
  status: 'success';
  normalizedName: string;
  prepPhrases: string[];
  sizePhrases: string[];
  synonyms: string[];
};

type AiNormalizeError = {
  status: 'error';
  reason: string;
};

const RESPONSE_SCHEMA = {
  name: 'ingredient_normalization',
  schema: {
    type: 'object',
    additionalProperties: false,
    properties: {
      normalized_name: { type: 'string' },
      prep_phrases: { type: 'array', items: { type: 'string' } },
      size_phrases: { type: 'array', items: { type: 'string' } },
      synonyms: { type: 'array', items: { type: 'string' } },
      error: { type: ['string', 'null'] },
    },
    required: ['normalized_name', 'prep_phrases', 'size_phrases', 'synonyms', 'error'],
  },
  strict: true,
};

const SYSTEM_PROMPT = [
  'You normalize ingredient strings for recipe mapping. Be VERY CONSERVATIVE.',
  '',
  'RULES:',
  '1. PRESERVE dietary modifiers: lowfat, nonfat, skim, reduced-fat, sugar-free, unsweetened, whole, etc.',
  '   "lowfat milk" → "lowfat milk" (NOT "milk")',
  '   "sugar-free yogurt" → "sugar-free yogurt" (NOT "yogurt")',
  '2. STRIP only prep phrases: chopped, diced, sliced, cooked, boiled, fresh, etc.',
  '3. STRIP measurements: 1 cup, 2 tbsp, etc.',
  '4. normalized_name should be MINIMAL changes from original - only remove prep/measurements.',
  '5. synonyms should ONLY include British→American translations or obvious alternate names.',
  '   Good synonyms: "courgette" → ["zucchini"], "aubergine" → ["eggplant"]',
  '   BAD synonyms: "lowfat milk" → ["milk"] ← WRONG, loses modifier!',
  '',
  'Return JSON with normalized_name (preserving modifiers), prep_phrases to strip, size_phrases, synonyms.',
  'If unclear, set error. Do NOT invent foods or strip important modifiers.',
].join(' ');

export async function aiNormalizeIngredient(
  rawLine: string,
  cleanedInput?: string
): Promise<AiNormalizeResult> {
  // Check persistent database cache first
  const cached = await getAiNormalizeCache(rawLine);
  if (cached) {
    // Apply deterministic synonyms to cached result too
    const fixedName = applySynonyms(cached.normalizedName);
    return {
      status: 'success',
      ...cached,
      normalizedName: fixedName,
    };
  }

  if (!OPENAI_API_KEY) {
    return { status: 'error', reason: 'OPENAI_API_KEY missing' };
  }

  const userPrompt = [
    `Raw: ${rawLine}`,
    cleanedInput ? `Cleaned: ${cleanedInput}` : '',
    'Respond with normalized_name (no qty/unit), prep_phrases, size_phrases, synonyms. If impossible, set error.',
  ]
    .filter(Boolean)
    .join('\n');

  try {
    const response = await fetch(`${OPENAI_API_BASE_URL}/chat/completions`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${OPENAI_API_KEY}`,
      },
      body: JSON.stringify({
        model: FATSECRET_CACHE_AI_MODEL,
        temperature: 0, // Deterministic
        response_format: { type: 'json_schema', json_schema: RESPONSE_SCHEMA },
        messages: [
          { role: 'system', content: SYSTEM_PROMPT },
          { role: 'user', content: userPrompt },
        ],
      }),
    });
    const json = await response.json();
    const content = json?.choices?.[0]?.message?.content;
    if (!content) {
      return { status: 'error', reason: 'empty AI response' };
    }
    const parsed = JSON.parse(content);
    if (parsed.error) {
      return { status: 'error', reason: parsed.error };
    }
    if (
      typeof parsed.normalized_name !== 'string' ||
      !Array.isArray(parsed.prep_phrases) ||
      !Array.isArray(parsed.size_phrases) ||
      !Array.isArray(parsed.synonyms)
    ) {
      return { status: 'error', reason: 'invalid AI response schema' };
    }

    // Apply deterministic synonyms (e.g., extra lean -> 96% lean)
    const normalizedName = applySynonyms(parsed.normalized_name);

    const result: AiNormalizeSuccess = {
      status: 'success',
      normalizedName: normalizedName,
      prepPhrases: parsed.prep_phrases.filter((p: unknown) => typeof p === 'string'),
      sizePhrases: parsed.size_phrases.filter((p: unknown) => typeof p === 'string'),
      synonyms: parsed.synonyms.filter((s: unknown) => typeof s === 'string'),
    };

    // Save to persistent database cache
    await saveAiNormalizeCache(rawLine, {
      normalizedName: result.normalizedName,
      synonyms: result.synonyms,
      prepPhrases: result.prepPhrases,
      sizePhrases: result.sizePhrases,
    });

    // Learn from AI response - save prep phrases and synonyms to learning tables
    // This builds our knowledge base over time, reducing future AI calls
    await learnFromAiResponse(result.normalizedName, {
      prepPhrases: result.prepPhrases,
      sizePhrases: result.sizePhrases,
      synonyms: result.synonyms,
    });

    return result;
  } catch (err) {
    return { status: 'error', reason: (err as Error).message };
  }
}
